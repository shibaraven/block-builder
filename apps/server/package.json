{
  "name": "@block-builder/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --tsconfig tsconfig.json src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@block-builder/types": "workspace:*",
    "@block-builder/codegen": "workspace:*",
    "hono": "^4.3.0",
    "@hono/node-server": "^1.11.0",
    "@hono/zod-validator": "^0.2.0",
    "zod": "^3.23.0",
    "drizzle-orm": "^0.30.0",
    "postgres": "^3.4.0",
    "mysql2": "^3.9.0",
    "drizzle-kit": "^0.21.0",
    "jose": "^5.2.0",
    "@libsql/client": "^0.6.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "tsx": "^4.10.0",
    "@types/node": "^20.0.0"
  }
}